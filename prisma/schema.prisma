// TIF v0.1 — Asset Production Spine
// Scope: Evidence Registry · Asset Opportunity Registry · Asset Composer · Traceability · Capture Inbox
// Explicitly excluded (stays DEFERRED per GOVERNANCE.md): knowledge graph, vector search, agent framework.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum BusinessUnit {
  rachel
  cre
  tko
}

enum ContentTenant {
  tko
  boundos
  rachel_delray
  cre_advisory
}

enum AssetType {
  article
  landing_page
  case_study
  assessment
  executive_brief
  comparison_guide
  intelligence_report
}

// Human Approved AI: every generated artifact starts at draft. Future statuses
// (review/approved/published) are modeled now so the pipeline isn't blocked later,
// but only draft is produced by v0.1 — no publishing/approval workflow is implemented.
enum AssetStatus {
  draft
  review
  approved
  published
}

enum CaptureSource {
  conversation
  phone_call
  client_work
  healthcare
  cre
  rachel
  personal_observation
  reddit
  linkedin
  web_research
}

enum CaptureStatus {
  inbox
  reviewed
  promoted
  archived
}

enum OpportunitySourceType {
  content_gap
  keyword
  title_idea
  competitor_url
  reddit_thread_url
  forum_discussion
  pasted_notes
  pasted_transcript
  existing_page_url
  existing_guide
}

enum RevisionRequestStatus {
  open
  applied
  dismissed
}

enum DerivativeAssetType {
  behavioral_content_brief
  cre_tenant_rep_brief
  cre_site_driveby_report
  cre_corridor_comparison
  cre_lease_decision_guide
  business_exit_readiness_brief
  business_transferability_assessment
  owner_operating_system_brief
  cre_field_video_brief
  story_page
  linkedin_post
  linkedin_carousel
  facebook_post
  instagram_post
  instagram_story
  instagram_reel_script
  reddit_post
  youtube_video_brief
  youtube_short_script
  video_shot_list
  meta_ad
  meta_ad_set
  meta_video_script
  meta_image_brief
  email_next_touch
  image_brief
  email_draft
  ad_concept
  summary
  executive_brief
}

// Capture Inbox (EPIC 11 TIF-1101 / TIF v0.2 Priority 1): lightweight intake, ahead of a
// normalized Evidence record. Capture-only — no edit endpoint is implemented (TIF v0.2 P1).
model CaptureItem {
  id           String        @id @default(cuid())
  slug         String        @unique
  title        String
  observation  String
  tags         String[]      @default([])
  source       CaptureSource
  status       CaptureStatus @default(inbox)
  businessUnit BusinessUnit?
  mediaUrl      String?
  mediaType     String?
  observedAt    DateTime?
  location      String?
  rightsStatus  String?
  transcript    String?

  promotedToEvidenceId String?
  promotedToEvidence   Evidence? @relation(fields: [promotedToEvidenceId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
}

// Inbound Lead Submission: durable capture for website contact and assessment forms.
// Duplicate awareness is intentionally lightweight: email is the stable key, while
// lastSubmittedAt records repeat submissions without creating unnecessary rows.
model InboundLead {
  id              String    @id @default(cuid())
  name            String?
  email           String    @unique
  company         String?
  role            String?
  source          String?
  landingPage     String?
  payload         Json
  notifiedAt      DateTime?
  lastSubmittedAt DateTime  @default(now())
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([source])
  @@index([createdAt])
}

// Content Inventory (TIF v0.2 Priority 2 / EPIC 12 TIF-1201): a flat record of existing
// intellectual property across tko-site, rachel-realestate, and cre-intelligence, captured
// for awareness before producing more content. Not linked into Evidence/Opportunity/Asset
// traceability — that mapping is a separate, future EPIC 12 deliverable.
model ContentInventoryItem {
  id           String       @id @default(cuid())
  slug         String       @unique
  title        String
  location     String // path or route within its repo
  repo         String // tko-site | rachel-realestate | cre-intelligence
  assetType    String // freeform: broader than AssetType (e.g. service_page, guide, proof_asset)
  businessUnit BusinessUnit

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([repo])
}

// Evidence Registry (TIF-604 / content/proof/*/evidence.yaml pattern, DB-backed).
// proofRef is a citation, not a foreign key — it may point at a code/migration ref,
// a screenshot, or an existing content/proof/*/evidence.yaml record id, per
// asset-production/METHOD.md §3's evidence rule.
model Evidence {
  id           String       @id @default(cuid())
  slug         String       @unique
  domain       String // healthcare | rachelos | cre | tko
  businessUnit BusinessUnit
  observation  String
  proofRef     String
  claimGuard   String

  capturedFrom  CaptureItem[]
  opportunities AssetOpportunityEvidence[]
  assets        AssetEvidence[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Asset Opportunity Registry (EPIC 11 TIF-1103).
model AssetOpportunity {
  id           String       @id @default(cuid())
  slug         String       @unique
  title        String
  tenant       ContentTenant @default(tko)
  businessUnit BusinessUnit
  assetType    AssetType
  angle        String
  audience     String?
  sourceType   OpportunitySourceType @default(title_idea)
  sourceUrl    String?
  contextNotes String?
  status       String       @default("opportunity") // opportunity -> composed

  evidenceLinks AssetOpportunityEvidence[]
  assets        Asset[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AssetOpportunityEvidence {
  opportunityId String
  opportunity   AssetOpportunity @relation(fields: [opportunityId], references: [id])
  evidenceId    String
  evidence      Evidence         @relation(fields: [evidenceId], references: [id])

  @@id([opportunityId, evidenceId])
}

// Asset Composer output (TIF-701..706, template-fill only — no AI/workflow engine).
model Asset {
  id             String      @id @default(cuid())
  slug           String      @unique
  title          String
  tenant         ContentTenant @default(tko)
  assetType      AssetType
  status         AssetStatus @default(draft)
  businessUnit   BusinessUnit
  outputPath     String
  generatedAt    DateTime?
  generatedHash  String?
  currentVersionNumber Int    @default(0)

  opportunityId  String?
  opportunity    AssetOpportunity? @relation(fields: [opportunityId], references: [id])

  evidenceLinks  AssetEvidence[]
  versions        AssetVersion[]
  revisionRequests RevisionRequest[]
  derivativeAssets DerivativeAsset[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AssetVersion {
  id            String   @id @default(cuid())
  assetId       String
  asset         Asset    @relation(fields: [assetId], references: [id])
  versionNumber Int
  title         String
  body          String
  revisionNotes String?
  createdBy     String   @default("operator")
  createdAt      DateTime @default(now())

  @@unique([assetId, versionNumber])
  @@index([assetId, createdAt])
}

model RevisionRequest {
  id            String                @id @default(cuid())
  assetId       String
  asset         Asset                 @relation(fields: [assetId], references: [id])
  versionNumber Int?
  notes         String
  status        RevisionRequestStatus @default(open)
  requestedBy   String?
  createdAt     DateTime              @default(now())
  appliedAt     DateTime?

  @@index([assetId, status])
}

model DerivativeAsset {
  id                  String              @id @default(cuid())
  assetId             String
  asset               Asset               @relation(fields: [assetId], references: [id])
  type                DerivativeAssetType
  body                String
  context             Json?
  behavioralStrategy Json?
  sourceVersionNumber Int?
  createdAt           DateTime            @default(now())

  @@index([assetId, type])
}

// Traceability (mandatory): every Asset cites the Evidence it was composed from,
// and every Evidence record can resolve its derived Assets via the same join table.
model AssetEvidence {
  assetId    String
  asset      Asset    @relation(fields: [assetId], references: [id])
  evidenceId String
  evidence   Evidence @relation(fields: [evidenceId], references: [id])

  @@id([assetId, evidenceId])
}
